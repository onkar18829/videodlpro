---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found">
	<section class="container mx-auto px-4 py-32 text-center">
		<h1 class="text-9xl font-black text-blue-600/20 mb-8">404</h1>
		<h2 class="text-4xl font-bold mb-4">Lost in Space?</h2>
		<p class="text-slate-600 dark:text-slate-400 mb-12 max-w-md mx-auto">
			The page you're looking for doesn't exist or has been moved to a different universe.
		</p>
		<a href="/" class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-bold px-8 py-4 rounded-2xl transition-all active:scale-95 shadow-lg shadow-blue-500/30">
			Take Me Home
		</a>
	</section>
</Layout>
